# Traffic Builder — Server Environment
# Copy to .env and fill in values. Never commit .env to source control.

# Google Maps Directions API key.
# Leave empty to run on mock data (no API calls, no cost).
GOOGLE_MAPS_DIRECTIONS_API_KEY=

# Nominatim geocoding base URL (no trailing slash).
NOMINATIM_SEARCH_ENDPOINT=https://nominatim.openstreetmap.org

# OpenStreetMap tile base URL (informational — consumed by the mobile app, not the server).
OPEN_STREET_MAP_API_ENDPOINT=https://tile.openstreetmap.org

# HTTP port the Express server listens on.
PORT=3001
